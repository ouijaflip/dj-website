<style>
	footer {
		padding: 1.25em 1em;
		background: rgba(10, 10, 14, 0.6);
		backdrop-filter: blur(10px);
		border-top: 1px solid rgba(var(--gray), 0.18);
		color: rgb(var(--gray));
		text-align: center;
		box-shadow: 0 -10px 30px rgba(0,0,0,0.35), 0 0 40px rgba(35, 55, 255, 0.08) inset;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1em;
		margin-bottom: 0.75em;
	}
	.social-links a {
		text-decoration: none;
		color: rgb(var(--gray));
	}
	.social-links a:hover {
		color: rgb(var(--gray-light));
		text-shadow: 0 0 10px rgba(35, 55, 255, 0.5);
	}
</style>
