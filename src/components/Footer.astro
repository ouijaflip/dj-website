---
const today = new Date();
---

<footer>
	<div class="wrap">
		<div class="foot-grid">
			<div class="foot-brand">
				<span class="logo-box">AEC</span>
				<div>
					<div class="foot-name">ADKINS EVENT CO</div>
					<div class="foot-model">DJ + Lighting · Pittsburgh &amp; Western PA</div>
				</div>
			</div>
			<nav class="foot-links" aria-label="Footer">
				<span class="label">Index</span>
				<a href="/">Home</a>
				<a href="/about">Services</a>
				<a href="/bookings">Bookings</a>
			</nav>
			<div class="foot-contact">
				<span class="label">Contact</span>
				<a href="tel:7242439327">724-243-9327</a>
				<a href="mailto:damonmckayadkins@gmail.com">damonmckayadkins@gmail.com</a>
			</div>
			<div class="foot-status">
				<span class="label">Status</span>
				<span class="stat"><span class="led"></span> Booking now</span>
				<span class="stat"><span class="led orange"></span> Reply &lt; 24h</span>
			</div>
		</div>
		<div class="foot-bottom">
			<span>&copy; {today.getFullYear()} ADKINS EVENT CO</span>
			<span class="label">All rights reserved</span>
		</div>
	</div>
</footer>

<style>
	footer {
		border-top: 1.5px solid var(--line);
		background: var(--panel);
		margin-top: 2rem;
	}
	.foot-grid {
		display: grid;
		grid-template-columns: 1.4fr 1fr 1.2fr 1fr;
		gap: 2rem;
		padding: 2.5rem 0 2rem;
		align-items: start;
	}
	.foot-brand { display: flex; gap: 0.7rem; align-items: center; }
	.logo-box {
		font-family: var(--font-mono);
		font-weight: 700;
		font-size: 0.9rem;
		background: var(--orange);
		color: #fff;
		border: 1.5px solid var(--line);
		border-radius: 4px;
		padding: 0.3rem 0.5rem;
	}
	.foot-name { font-weight: 800; letter-spacing: 0.01em; }
	.foot-model { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.12em; color: var(--muted); }
	.foot-links, .foot-contact, .foot-status { display: flex; flex-direction: column; gap: 0.45rem; }
	.foot-links .label, .foot-contact .label, .foot-status .label { margin-bottom: 0.3rem; }
	.foot-links a, .foot-contact a { font-family: var(--font-mono); font-size: 0.82rem; color: var(--ink); }
	.foot-links a:hover, .foot-contact a:hover { color: var(--orange); }
	.stat { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--font-mono); font-size: 0.75rem; color: var(--muted); }
	.foot-bottom {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.6rem;
		border-top: 1.5px solid var(--line);
		padding: 1.1rem 0;
		font-family: var(--font-mono);
		font-size: 0.72rem;
		color: var(--muted);
	}
	@media (max-width: 820px) {
		.foot-grid { grid-template-columns: 1fr 1fr; gap: 1.6rem; }
	}
	@media (max-width: 480px) {
		.foot-grid { grid-template-columns: 1fr; }
	}
</style>
