---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
import { ViewTransitions } from 'astro:transitions';

const siteTitle = SITE_TITLE;

// Split title into segments for styling: "Star " (gold), "Lake" (futuristic), " Events" (complementary)
const starMatch = siteTitle.match(/^Star\s/);
const starPrefix = starMatch ? starMatch[0] : '';
const remainingAfterStar = starMatch ? siteTitle.slice(starMatch[0].length) : siteTitle;
const lakeMatch = remainingAfterStar.match(/^Lake\s/);
const lakePart = lakeMatch ? lakeMatch[0].trim() : '';
const eventsPart = lakeMatch ? remainingAfterStar.slice(lakeMatch[0].length) : '';
---

<ViewTransitions />
<header>
	<nav>
		<h2>
			<a href="/" class="brand-link">
				{starPrefix && (
					<>
						<span class="brand-pgh">{starPrefix}</span>
						<span class="brand-dynamic">{lakePart}</span>
						<span class="brand-events"> {eventsPart}</span>
					</>
				) || (
					SITE_TITLE
				)}
			</a>
		</h2>
		<div class="internal-links">
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/bookings">Bookings</HeaderLink>
		</div>
		<div class="social-links">
			<a href="tel:724-243-9327">
				<span class="sr-only">Call us</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
				</svg>
			</a>
			<a href="mailto:damonmckayadkins@gmail.com">
				<span class="sr-only">Email us</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<rect x="2" y="4" width="20" height="16" rx="2"></rect>
					<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
				</svg>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: rgba(10, 10, 14, 0.6);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid rgba(var(--gray), 0.18);
		box-shadow: 0 10px 30px rgba(0,0,0,0.35), 0 0 40px rgba(35, 55, 255, 0.08);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.75em;
		color: rgb(var(--gray-light));
		border-bottom: 2px solid transparent;
		text-decoration: none;
		transition: color 0.2s ease, text-shadow 0.2s ease, border-color 0.2s ease;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
		text-shadow: 0 0 10px rgba(35, 55, 255, 0.5);
	}
	nav a:hover {
		border-bottom-color: var(--accent);
		text-shadow: 0 0 10px rgba(35, 55, 255, 0.5);
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	.internal-links { gap: 0.25rem; }
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
.brand-pgh {
	color: #d4af37;
	font-weight: bold;
	letter-spacing: 0.05em;
}
.brand-dynamic {
	background: linear-gradient(92deg, #00d9ff, #0099ff);
	-webkit-background-clip: text;
	background-clip: text;
	color: transparent;
	text-shadow: 0 0 10px rgba(0, 217, 255, 0.4);
	font-family: 'Arial Black', sans-serif;
	font-weight: 900;
	letter-spacing: -0.02em;
}
.brand-i {
	/* Inherit all styling from parent .brand-dynamic */
}
.brand-events {
	background: linear-gradient(92deg, #ff6b9d, #ff96c7);
	-webkit-background-clip: text;
	background-clip: text;
	color: transparent;
	text-shadow: 0 0 10px rgba(255, 107, 157, 0.4);
}
</style>
</style>
