---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
import { ViewTransitions } from 'astro:transitions';

const siteTitle = SITE_TITLE;
const idx = siteTitle.search(/i/i);
const titleBefore = idx !== -1 ? siteTitle.slice(0, idx) : siteTitle;
const titleI = idx !== -1 ? siteTitle[idx] : '';
const titleAfter = idx !== -1 ? siteTitle.slice(idx + 1) : '';

// Split title into segments for styling: "PGH " (gold), "Dynam" + "i" + "c" (futuristic), " Events" (complementary)
const pghMatch = siteTitle.match(/^PGH\s/);
const pghPrefix = pghMatch ? pghMatch[0] : '';
const remainingAfterPgh = pghMatch ? siteTitle.slice(pghMatch[0].length) : siteTitle;
const dynamicMatch = remainingAfterPgh.match(/^Dynamic\s/);
const dynamicPart = dynamicMatch ? dynamicMatch[0].trim() : '';
const eventsPart = dynamicMatch ? remainingAfterPgh.slice(dynamicMatch[0].length) : '';
const beforeI = dynamicMatch ? 'Dynam' : '';
const iChar = dynamicMatch ? 'i' : '';
const afterI = dynamicMatch ? 'c' : '';
---

<ViewTransitions />
<header>
	<nav>
		<h2>
			<a href="/" class="brand-link">
				{pghPrefix && (
					<>
						<span class="brand-pgh">{pghPrefix}</span>
						<span class="brand-dynamic">{beforeI}<span class="brand-i">{iChar}</span>{afterI}</span>
						<span class="brand-events"> {eventsPart.charAt(0).toUpperCase() + eventsPart.slice(1)}</span>
					</>
				) || (titleI ? (
					<>
						{titleBefore}<span class="brand-i">{titleI}</span>{titleAfter}
					</>
				) : (
					SITE_TITLE
				))}
			</a>
		</h2>
		<div class="internal-links">
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/bookings">Bookings</HeaderLink>
		</div>
		<div class="social-links">
			<a href="tel:724-243-9327">
				<span class="sr-only">Call us</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32">
					<path fill="currentColor" d="M3.654 1.328a.5.5 0 0 0-.282.732l.147.353a.5.5 0 0 0 .916-.182l-.147-.353a.5.5 0 0 0-.734-.28zm2.27 7.693a.5.5 0 1 0 .894-.447l-.894.447zm9.323-5.206a.5.5 0 0 0-.684-.187l-.03.025C13.769 4.362 12.769 5.747 11 7.072V4.5a.5.5 0 0 0-1 0v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 0-1h-2.475a8.975 8.975 0 0 1 1.308-1.573.5.5 0 0 0 .187-.684zM6.5 10a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3z"/>
				</svg>
			</a>
			<a href="mailto:damonmckayadkins@gmail.com">
				<span class="sr-only">Email us</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32">
					<path fill="currentColor" d="M.05 3.555A2 2 0 0 1 2 2h12a2 2 0 0 1 1.95 1.555l-1.974 5.922A2.98 2.98 0 0 1 14 8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2c0-.315.031-.618.09-.909L.05 3.555zM2 4a1 1 0 0 0-.966.741l1.921 5.762A1 1 0 0 0 4 10h8a1 1 0 0 0 .966-.741l1.921-5.762A1 1 0 0 0 14 4H2z"/>
				</svg>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: rgba(10, 10, 14, 0.6);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid rgba(var(--gray), 0.18);
		box-shadow: 0 10px 30px rgba(0,0,0,0.35), 0 0 40px rgba(35, 55, 255, 0.08);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.75em;
		color: rgb(var(--gray-light));
		border-bottom: 2px solid transparent;
		text-decoration: none;
		transition: color 0.2s ease, text-shadow 0.2s ease, border-color 0.2s ease;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
		text-shadow: 0 0 10px rgba(35, 55, 255, 0.5);
	}
	nav a:hover {
		border-bottom-color: var(--accent);
		text-shadow: 0 0 10px rgba(35, 55, 255, 0.5);
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	.internal-links { gap: 0.25rem; }
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
.brand-pgh {
	color: #d4af37;
	font-weight: bold;
	letter-spacing: 0.05em;
}
.brand-dynamic {
	background: linear-gradient(92deg, #00d9ff, #0099ff);
	-webkit-background-clip: text;
	background-clip: text;
	color: transparent;
	text-shadow: 0 0 10px rgba(0, 217, 255, 0.4);
	font-family: 'Arial Black', sans-serif;
	font-weight: 900;
	letter-spacing: -0.02em;
}
.brand-i {
	/* Inherit all styling from parent .brand-dynamic */
}
.brand-events {
	background: linear-gradient(92deg, #ff6b9d, #ff96c7);
	-webkit-background-clip: text;
	background-clip: text;
	color: transparent;
	text-shadow: 0 0 10px rgba(255, 107, 157, 0.4);
}
</style>
</style>
