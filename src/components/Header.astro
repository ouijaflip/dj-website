---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
import { ViewTransitions } from 'astro:transitions';
---

<ViewTransitions />
<header>
	<div class="wrap bar">
		<a href="/" class="brand" aria-label={`${SITE_TITLE} home`}>
			<span class="logo-box">AEC</span>
			<span class="brand-text">
				<span class="brand-name">ADKINS EVENT CO</span>
				<span class="brand-model">DJ + Lighting · Pittsburgh</span>
			</span>
		</a>
		<nav class="links" aria-label="Primary">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/about">Services</HeaderLink>
			<HeaderLink href="/bookings">Bookings</HeaderLink>
		</nav>
		<div class="right">
			<a href="/bookings" class="btn btn-primary book">Book</a>
		</div>
	</div>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 50;
		background: var(--panel);
		border-bottom: 1.5px solid var(--line);
	}
	.bar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.6rem 0;
	}
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.65rem;
		text-decoration: none;
		color: var(--ink);
	}
	.logo-box {
		font-family: var(--font-mono);
		font-weight: 700;
		font-size: 0.95rem;
		background: var(--orange);
		color: #fff;
		border: 1.5px solid var(--line);
		border-radius: 4px;
		padding: 0.3rem 0.5rem;
		letter-spacing: 0.04em;
	}
	.brand-text { display: flex; flex-direction: column; line-height: 1.1; }
	.brand-name { font-weight: 800; letter-spacing: 0.01em; font-size: 1rem; }
	.brand-model { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.04em; color: var(--muted); }
	.links { display: flex; gap: 0.2rem; }
	.links :global(a) {
		font-family: var(--font-mono);
		font-size: 0.78rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--muted);
		padding: 0.4rem 0.7rem;
		border: 1.5px solid transparent;
		border-radius: 4px;
	}
	.links :global(a:hover) { color: var(--ink); border-color: var(--line); }
	.links :global(a.active) { color: #fff; background: var(--purple); border-color: var(--purple); }
	.right { display: flex; align-items: center; gap: 0.9rem; }
	.book { padding: 0.5rem 0.9rem; font-size: 0.78rem; }
	@media (max-width: 760px) {
		.brand-model, .links { display: none; }
	}
</style>
