---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const eqHeights = Array.from({ length: 54 }, () => Math.round(20 + Math.random() * 68));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="wrap">
					<div class="eqband reveal in" aria-hidden="true">
						{eqHeights.map((h, i) => <span style={`--h:${h}%;--d:${-(i % 10) * 0.11}s`} />)}
					</div>
					<div class="hero-copy">
						<span class="label"><span class="led blink"></span> DJ + Lighting — Pittsburgh, PA</span>
						<h1 class="hero-title">DJ + lighting for your <span class="hl">Pittsburgh event.</span></h1>
						<p class="hero-sub">
							Adkins Event Co handles DJ and lighting for weddings, private parties, and corporate events
							in and around Pittsburgh — pro sound, custom lighting, and a DJ who actually reads the room.
						</p>
						<div class="hero-actions">
							<a href="/bookings" class="btn btn-primary">Check your date →</a>
							<a href="/about" class="btn btn-ghost">View services</a>
						</div>
					</div>
				</div>
				<div class="ticker" aria-hidden="true">
					<div class="ticker-track">
						<span>WEDDINGS · PRIVATE PARTIES · CORPORATE · UPLIGHTING · OPEN-FORMAT · MC HOSTING · PRO SOUND ·</span>
						<span>WEDDINGS · PRIVATE PARTIES · CORPORATE · UPLIGHTING · OPEN-FORMAT · MC HOSTING · PRO SOUND ·</span>
					</div>
				</div>
			</section>

			<section class="section" id="services">
				<div class="wrap">
					<div class="mod-head reveal">
						<span class="num">01</span>
						<span class="label">Services</span>
					</div>
					<div class="service-grid">
						<article class="card service">
							<div class="service-top">
								<span class="ch">A</span>
							</div>
							<h3>Weddings</h3>
							<p>Ceremony through last dance: DJ sets built around your music, MC hosting for the key moments, and uplighting set up for your venue.</p>
							<ul>
								<li>Ceremony + reception</li>
								<li>Wireless mics</li>
								<li>Custom lighting design</li>
							</ul>
						</article>
						<article class="card service">
							<div class="service-top">
								<span class="ch">B</span>
							</div>
							<h3>Private Parties &amp; Gatherings</h3>
							<p>DJ and lighting for private parties and gatherings of any size, with music built around your crowd.</p>
							<ul>
								<li>Open-format mixing</li>
								<li>Lighting + ambiance</li>
								<li>Flexible setup</li>
							</ul>
						</article>
						<article class="card service">
							<div class="service-top">
								<span class="ch">C</span>
							</div>
							<h3>Corporate &amp; Galas</h3>
							<p>Sound, lighting, and AV support for launches, galas, and holiday parties.</p>
							<ul>
								<li>Pro sound + AV</li>
								<li>Stage + projection</li>
								<li>Event coordination</li>
							</ul>
						</article>
					</div>
				</div>
			</section>

			<section class="section spec-section">
				<div class="wrap">
					<div class="mod-head reveal">
						<span class="num">02</span>
						<span class="label">What's included</span>
					</div>
					<div class="spec-grid reveal">
						<div class="spec"><span class="spec-k">Format</span><span class="spec-v">Open / all genres</span></div>
						<div class="spec"><span class="spec-k">Audio</span><span class="spec-v">Pro PA system</span></div>
						<div class="spec"><span class="spec-k">Lighting</span><span class="spec-v">Full rig + uplighting</span></div>
						<div class="spec"><span class="spec-k">Hosting</span><span class="spec-v">Live MC</span></div>
						<div class="spec"><span class="spec-k">Coverage</span><span class="spec-v">Pittsburgh + W. PA</span></div>
						<div class="spec"><span class="spec-k">Reply</span><span class="spec-v">Within 24 hours</span></div>
					</div>
				</div>
			</section>

			<section class="section">
				<div class="wrap split">
					<div class="split-copy reveal">
						<span class="label">The difference</span>
						<h2>Live mixing, not a playlist.</h2>
						<p>
							Playing a good playlist and DJing a room are different jobs. We mix live, adjust to the
							crowd as the night goes, and time the lighting to the music instead of running it on a preset loop.
						</p>
						<ul class="feature-list">
							<li><strong>Live open-format mixing</strong> — nothing pre-programmed</li>
							<li><strong>Lighting synced to the music</strong> — uplighting, effects, ambiance</li>
							<li><strong>Pro audio</strong> — tuned to your room and crowd size</li>
							<li><strong>MC hosting when you want it</strong> — no forced bits</li>
							<li><strong>Add-ons available</strong> — karaoke, video DJing, stage lighting</li>
						</ul>
						<a href="/bookings" class="btn btn-primary">Lock in your date</a>
					</div>
					<div class="split-visual reveal" aria-hidden="true">
						<div class="pad-grid">
							{Array.from({ length: 16 }).map((_, i) => <span class={`pad${[0, 3, 5, 6, 9, 10, 12, 15].includes(i) ? ' lit' : ''}`} />)}
						</div>
					</div>
				</div>
			</section>

			<section class="section" id="how">
				<div class="wrap">
					<div class="mod-head reveal">
						<span class="num">03</span>
						<span class="label">How it works</span>
					</div>
					<div class="steps">
						<div class="step card reveal">
							<div class="step-n">01</div>
							<h3>Reach out</h3>
							<p>Send your date, venue, and vibe. We reply within 24 hours with availability.</p>
						</div>
						<div class="step card reveal">
							<div class="step-n">02</div>
							<h3>Plan the night</h3>
							<p>We build your timeline, must-plays, do-not-plays, and lighting look together.</p>
						</div>
						<div class="step card reveal">
							<div class="step-n">03</div>
							<h3>Pack the floor</h3>
							<p>Show night: pro sound, live mixing, and lighting that reads the room.</p>
						</div>
					</div>
				</div>
			</section>

			<section class="section">
				<div class="wrap">
					<div class="cta-panel reveal">
						<div class="cta-copy">
							<span class="label"><span class="led orange blink"></span> Ready when you are</span>
							<h2>Get a quote for your date.</h2>
							<p>Dates book fast, especially in season. Tell us about your event and we'll reply within 24 hours.</p>
						</div>
						<div class="cta-actions">
							<a href="/bookings" class="btn btn-primary">Check availability →</a>
							<a href="tel:7242439327" class="btn btn-ghost">Call 724-243-9327</a>
						</div>
					</div>
				</div>
			</section>
		</main>
		<Footer />
		<script>
			// Lightweight scroll-reveal
			(function () {
				const els = document.querySelectorAll('.reveal');
				if (!('IntersectionObserver' in window) || !els.length) {
					els.forEach((e) => e.classList.add('in'));
					return;
				}
				const io = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								entry.target.classList.add('in');
								io.unobserve(entry.target);
							}
						});
					},
					{ threshold: 0.12 },
				);
				els.forEach((e) => io.observe(e));
			})();
		</script>
	</body>
</html>

<style>
	main { margin: 0; padding: 0; width: 100%; }

	.hero { position: relative; padding: clamp(3rem, 8vw, 6rem) 0 0; overflow: hidden; }
	.eqband { position: absolute; inset: 0; opacity: 0.35; z-index: 0; }
	.hero-copy { position: relative; z-index: 1; max-width: 760px; padding-bottom: clamp(2rem, 6vw, 4rem); }
	.hero-copy .label { display: inline-flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem; }
	.hero-title { margin: 0.6rem 0 1rem; }
	.hero-title .hl { color: var(--purple-2); }
	.hero-sub { max-width: 560px; color: var(--muted); font-size: 1.05rem; }
	.hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 1.6rem; }

	.ticker {
		position: relative;
		border-top: 1.5px solid var(--line);
		border-bottom: 1.5px solid var(--line);
		background: var(--panel);
		overflow: hidden;
		padding: 0.6rem 0;
	}
	.ticker-track {
		display: flex;
		width: max-content;
		font-family: var(--font-mono);
		font-size: 0.78rem;
		letter-spacing: 0.1em;
		color: var(--muted);
		animation: ticker 22s linear infinite;
		white-space: nowrap;
	}
	@keyframes ticker { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

	.service-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.1rem; }
	.service { padding: 1.5rem; }
	.service-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.8rem; }
	.ch { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.1em; border: 1.5px solid var(--line); border-radius: 3px; padding: 0.15rem 0.45rem; }
	.service p { color: var(--muted); font-size: 0.92rem; }
	.service ul { list-style: none; padding: 0; margin: 1rem 0 0; }
	.service li { font-family: var(--font-mono); font-size: 0.78rem; padding: 0.4rem 0 0.4rem 1.2rem; position: relative; border-top: 1px solid var(--hair); }
	.service li:before { content: '▸'; position: absolute; left: 0; color: var(--orange); }
	.service.featured { background: var(--purple); color: #fff; border-color: var(--purple); }
	.service.featured h3, .service.featured .ch { color: #fff; }
	.service.featured .ch { border-color: #ffffff80; }
	.service.featured p { color: #ffffffcc; }
	.service.featured li { border-color: #ffffff38; }
	.service.featured li:before { color: #fff; }

	.spec-grid { display: grid; grid-template-columns: repeat(6, 1fr); border: 1.5px solid var(--line); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow); background: var(--panel); }
	.spec { display: flex; flex-direction: column; gap: 0.3rem; padding: 1.1rem 1.2rem; border-right: 1.5px solid var(--line); border-bottom: 1.5px solid var(--line); }
	.spec-k { font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }
	.spec-v { font-weight: 700; font-size: 0.9rem; }

	.split { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 3rem; align-items: center; }
	.split-copy p { color: var(--muted); max-width: 520px; }
	.feature-list { list-style: none; padding: 0; margin: 1.4rem 0 1.8rem; display: flex; flex-direction: column; gap: 0.6rem; }
	.feature-list li { font-family: var(--font-mono); font-size: 0.85rem; color: var(--muted); }
	.feature-list strong { color: var(--ink); }
	.pad-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.6rem; background: var(--panel); border: 1.5px solid var(--line); border-radius: var(--radius); padding: 1.2rem; box-shadow: var(--shadow); }
	.pad { aspect-ratio: 1; border-radius: 4px; background: var(--panel-2); border: 1.5px solid var(--line); }
	.pad.lit { background: var(--purple); border-color: var(--purple); box-shadow: 0 0 16px rgba(168, 85, 247, 0.5); }

	.steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.1rem; }
	.step { padding: 1.5rem; }
	.step-n { font-family: var(--font-mono); font-size: 0.75rem; color: var(--muted); margin-bottom: 0.6rem; }
	.step p { color: var(--muted); font-size: 0.92rem; margin: 0; }

	.cta-panel { display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; background: var(--orange); color: #fff; border: 1.5px solid var(--line); border-radius: 10px; box-shadow: var(--shadow-lg); padding: clamp(1.8rem, 4vw, 2.6rem); }
	.cta-panel h2 { color: #fff; }
	.cta-panel .label { color: #ffffffe6; display: inline-flex; align-items: center; gap: 0.5rem; }
	.cta-copy p { color: #ffffffe6; margin: 0.4rem 0 0; }
	.cta-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
	.cta-panel .btn-primary { background: #14101c; color: #fff; border-color: #14101c; }

	@media (max-width: 900px) {
		.service-grid, .steps { grid-template-columns: 1fr; }
		.spec-grid { grid-template-columns: repeat(2, 1fr); }
		.split { grid-template-columns: 1fr; }
	}
</style>
