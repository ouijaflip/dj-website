---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Services — Adkins Event Co"
			description="DJ, lighting, and event production packages for weddings, private parties, and corporate events."
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-hero">
				<div class="wrap">
					<span class="label">Services</span>
					<h1>Services &amp;<br />packages.</h1>
					<p class="lead">
						DJ, lighting, and hosting for weddings, private parties, and corporate events — built around
						your event, not a fixed script.
					</p>
				</div>
			</section>

			<section class="section">
				<div class="wrap">
					<div class="mod-head reveal">
						<span class="num">01</span>
						<span class="label">Packages</span>
					</div>
					<div class="grid-3">
						<article class="card pkg">
							<div class="pkg-top">
								<span class="ch">A</span>
							</div>
							<h3>Weddings &amp; Events</h3>
							<ul>
								<li>Ceremony + reception coverage</li>
								<li>Pro audio + wireless mics</li>
								<li>Custom uplighting design</li>
								<li>MC hosting + timeline</li>
							</ul>
						</article>
						<article class="card pkg">
							<div class="pkg-top">
								<span class="ch">B</span>
							</div>
							<h3>Private Parties &amp; Gatherings</h3>
							<ul>
								<li>Open-format DJ sets</li>
								<li>Lighting + effects</li>
								<li>Flexible for any space</li>
								<li>Music built around your crowd</li>
							</ul>
						</article>
						<article class="card pkg">
							<div class="pkg-top">
								<span class="ch">C</span>
							</div>
							<h3>Corporate &amp; Galas</h3>
							<ul>
								<li>Pro sound + AV setup</li>
								<li>Stage + projection</li>
								<li>Presentation support</li>
								<li>Event coordination</li>
							</ul>
						</article>
					</div>
				</div>
			</section>

			<section class="section">
				<div class="wrap">
					<div class="mod-head reveal">
						<span class="num">02</span>
						<span class="label">Why us</span>
					</div>
					<div class="why-grid reveal">
						<div class="why-item"><span class="led"></span>Read-the-room curation</div>
						<div class="why-item"><span class="led"></span>Small, unobtrusive setup</div>
						<div class="why-item"><span class="led"></span>Straightforward MC hosting, no forced jokes</div>
						<div class="why-item"><span class="led"></span>Shows up on time, runs on schedule</div>
						<div class="why-item"><span class="led"></span>Weddings + private parties + corporate</div>
					</div>
				</div>
			</section>

			<section class="section">
				<div class="wrap">
					<div class="cta-panel reveal">
						<div>
							<span class="label">Availability</span>
							<h2>Ready to check availability?</h2>
							<p>Check availability and get a tailored quote within 24 hours.</p>
						</div>
						<a href="/bookings" class="btn btn-primary">Check availability →</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />
		<script>
			// Lightweight scroll-reveal
			(function () {
				const els = document.querySelectorAll('.reveal');
				if (!('IntersectionObserver' in window) || !els.length) {
					els.forEach((e) => e.classList.add('in'));
					return;
				}
				const io = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								entry.target.classList.add('in');
								io.unobserve(entry.target);
							}
						});
					},
					{ threshold: 0.12 },
				);
				els.forEach((e) => io.observe(e));
			})();
		</script>
	</body>
</html>

<style>
	main { margin: 0; padding: 0; width: 100%; }
	.page-hero { padding: clamp(2rem, 6vw, 4rem) 0 1rem; }
	.page-hero h1 { margin-top: 0.6rem; }
	.lead { max-width: 620px; margin-top: 1rem; color: var(--muted); font-size: 1.05rem; }
	.grid-3 { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1.1rem; }
	.pkg { padding: 1.5rem; }
	.pkg-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.8rem; }
	.ch { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.1em; border: 1.5px solid var(--line); border-radius: 3px; padding: 0.15rem 0.45rem; }
	.pkg ul { list-style: none; padding: 0; margin: 1rem 0 0; }
	.pkg li { font-family: var(--font-mono); font-size: 0.78rem; padding: 0.4rem 0 0.4rem 1.2rem; position: relative; border-top: 1px solid var(--hair); }
	.pkg li:before { content: '▸'; position: absolute; left: 0; color: var(--orange); }
	.pkg.featured { background: var(--purple); color: #fff; border-color: var(--purple); }
	.pkg.featured h3 { color: #fff; }
	.pkg.featured .ch { color: #fff; border-color: #ffffff80; }
	.pkg.featured li { border-color: #ffffff38; }
	.pkg.featured li:before { color: #fff; }

	.why-grid { display: grid; grid-template-columns: repeat(3, 1fr); border: 1.5px solid var(--line); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow); background: var(--panel); }
	.why-item { display: flex; align-items: center; gap: 0.7rem; font-family: var(--font-mono); font-size: 0.82rem; padding: 1.1rem 1.2rem; border-right: 1.5px solid var(--line); border-bottom: 1.5px solid var(--line); }

	.cta-panel { display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; background: var(--orange); color: #fff; border: 1.5px solid var(--line); border-radius: 10px; box-shadow: var(--shadow-lg); padding: clamp(1.8rem, 4vw, 2.6rem); }
	.cta-panel h2 { color: #fff; }
	.cta-panel .label { color: #ffffffe6; }
	.cta-panel p { color: #ffffffe6; margin: 0.4rem 0 0; }
	.cta-panel .btn-primary { background: #14101c; color: #fff; border-color: #14101c; }

	@media (max-width: 900px) {
		.grid-3, .why-grid { grid-template-columns: 1fr; }
	}
</style>
